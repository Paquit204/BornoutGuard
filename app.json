{
  "expo": {
    "name": "BurnoutGuard",
    "slug": "burnoutguard",
    "version": "1.0.0",
    "scheme": "burnoutguard",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.anonymous.burnoutguard"
    },
    "ios": {
      "supportsTablet": true
    }
  }
}
