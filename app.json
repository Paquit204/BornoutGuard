{
  "expo": {
    "name": "BurnoutGuard",
    "slug": "burnoutguard",
    "version": "1.0.0",
    "scheme": "burnoutguard",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
